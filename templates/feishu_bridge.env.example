# Copy to a private location such as /etc/research-code-agent/feishu-bridge.env.
# Do not commit the copied file.

# Feishu self-built app credentials for Feishu Channel SDK Python.
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx

# Fixed whitelist. Use Feishu open_id values, comma-separated.
RCA_FEISHU_ALLOWED_OPEN_IDS=ou_xxx,ou_yyy

# OpenCode must listen on localhost only.
OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=change-this-long-random-password

# Baseline project directory where OpenCode should work.
RCA_PROJECT_DIR=/path/to/baseline-project

# Local runtime files. Keep them outside Git or under ignored logs/.
BRIDGE_DB_PATH=/path/to/baseline-project/logs/feishu_opencode_bridge.sqlite3
BRIDGE_LOG_PATH=/path/to/baseline-project/logs/feishu_opencode_bridge.jsonl
BRIDGE_TIMEOUT_SECONDS=600
RCA_BRIDGE_CHUNK_CHARS=2500

# Reply format: card is the default. Set markdown if the Feishu SDK/card
# renderer is incompatible in your tenant.
BRIDGE_REPLY_FORMAT=card

# Optional OpenCode defaults. Leave empty to use OpenCode config defaults.
OPENCODE_AGENT=
OPENCODE_MODEL_PROVIDER=
OPENCODE_MODEL_ID=

# Optional bridge text.
RCA_BRIDGE_ACK_TEXT=收到，处理中。
RCA_BRIDGE_BUSY_TEXT=当前会话已有任务处理中，请稍后再试。
RCA_BRIDGE_UNAVAILABLE_TEXT=OpenCode 调用失败，请查看 bridge 日志。
RCA_BRIDGE_TIMEOUT_TEXT=处理超时，已尝试中止当前 OpenCode 会话任务，请到服务器检查日志。
