# Git only tracks files useful for running, developing, or maintaining the project after cloning.
# Local papers, runtime logs, experiment outputs, checkpoints, datasets, model weights, and secrets are ignored.

# Papers and paper context
papers/
PAPER_CONTEXT.md

# Runtime logs and outputs
logs/
outputs/

